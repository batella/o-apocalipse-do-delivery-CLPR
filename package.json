{
  "name": "o-apocalipse-do-delivery",
  "version": "2.0.0",
  "description": "Microsservico de Checkout resiliente da EntregasJa - Fase 2",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest",
    "test:unit": "jest test/unit",
    "test:bdd": "jest test/integration",
    "test:coverage": "jest --coverage",
    "test:mutation": "stryker run"
  },
  "jest": {
    "testMatch": [
      "**/test/unit/**/*.test.js",
      "**/test/integration/**/*.steps.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  },
  "keywords": ["testing", "tdd", "bdd", "resilience", "sre"],
  "author": "Grupo CLPR - PUC Minas",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^8.2.6",
    "@stryker-mutator/jest-runner": "^8.2.6",
    "jest": "^29.7.0",
    "jest-cucumber": "^3.0.1"
  }
}
